# Secrets — NEVER commit
.env
.env.local
.env.*.local
*.key
*.pem

# Broken/old git dir and session logs
.git-broken/
logs/
conntest.log
*.log

# Competitor research screenshots — big binaries, kept locally only
clients/*/competitor-analyses/product-images/

# Generated media binaries — reproducible from prompts (image-prompts.md is tracked)
clients/*/generated/images/*
clients/*/generated/videos/*
!clients/*/generated/images/.gitkeep
!clients/*/generated/videos/.gitkeep

# Node
node_modules/
.npm/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# HyperFrames build artifacts
dist/
build/
out/
*.mp4
*.mov
*.webm
# (Keep finished renders out of git — they're big. Store in cloud or a separate assets backup.)

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp
*.swo

# Sandbox cache from cloned repos
main-source/hyperframes/node_modules/
examples/*/node_modules/
compositions/*/node_modules/

# ========================================================
# Cloned REFERENCE repos — too big (~940MB) to commit.
# These are excluded from this repo. To restore them after
# a fresh clone, run: ./setup.sh
# ========================================================
main-source/hyperframes/
examples/launch-video/
examples/student-kit/

# Keep the empty container folders tracked via .gitkeep
!main-source/.gitkeep
!examples/.gitkeep

# ========================================================
# outputs/ — track lightweight markdown analyses, ignore big binaries
# ========================================================
outputs/downloads/*
outputs/generated-images/*
outputs/voiceovers/*

# But keep the folder structure visible via .gitkeep
!outputs/downloads/.gitkeep
!outputs/generated-images/.gitkeep
!outputs/voiceovers/.gitkeep

# Keep video-analyses (markdown reports) tracked — they're our intel library

# ========================================================
# clients/ — track strategy markdown, ignore client binary assets
# ========================================================
# Ignore everything inside any client's assets/ folder...
clients/*/assets/*
# ...but keep .gitkeep so the folder structure is preserved
!clients/*/assets/.gitkeep
# And keep markdown notes if anyone drops them in assets/
!clients/*/assets/*.md

