# ============================================================
# API KEYS — copy this file to .env (without .example) and fill in
# IMPORTANT: never commit .env to git. .gitignore already excludes it.
# ============================================================

# --- OpenAI (for GPT Image 2.0 and other models) -----------------
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional: org and project IDs if you use them
# OPENAI_ORG_ID=org-...
# OPENAI_PROJECT_ID=proj_...


# --- HeyGen (for AI avatars and template videos) ----------------
# Get yours at: https://app.heygen.com/settings (API tab)
HEYGEN_API_KEY=...

# Optional: default avatar and voice IDs you reuse
# HEYGEN_DEFAULT_AVATAR_ID=...
# HEYGEN_DEFAULT_VOICE_ID=...


# --- Google Gemini (for the video-analyzer skill) --------------
# The video-analyzer skill uses Gemini's vision model to "watch"
# videos because Claude can't natively view video files yet.
# Get yours free at: https://aistudio.google.com/apikey
GEMINI_API_KEY=...


# --- Anthropic (optional, if you use Claude API directly) ------
# Get yours at: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-...


# --- ElevenLabs (optional, alternative TTS provider) -----------
# HyperFrames ships with Kokoro TTS built in (free, local), so
# only add this if you want premium voices.
# Get yours at: https://elevenlabs.io/app/settings/api-keys
# ELEVENLABS_API_KEY=...


# --- Workspace settings ----------------------------------------
# Default output resolution for renders (override per-project)
DEFAULT_WIDTH=1920
DEFAULT_HEIGHT=1080
DEFAULT_FPS=30
